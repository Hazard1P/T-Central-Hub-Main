# T-Central Hub environment template
# Copy this file to .env.local for local development and set matching variables in Vercel for production.
# Never commit real secrets.

# -----------------------------------------------------------------------------
# App URLs + session cryptography
# Required in production, for Steam login redirects, and for protected PayPal donation/subscription return URLs.
# NEXT_PUBLIC_APP_URL is the public browser-facing origin. APP_URL is the trusted server-side origin.
# SESSION_SECRET signs/encrypts the Steam session cookie; use a long random secret in production.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
SESSION_SECRET="replace-with-a-long-random-secret"

# -----------------------------------------------------------------------------
# Steam login
# Steam OpenID login uses NEXT_PUBLIC_APP_URL for the callback origin and SESSION_SECRET for the session cookie.
# STEAM_API_KEY is required when you want enriched Steam profile data during login; without it the app can fall back to a SteamID-only session.
# -----------------------------------------------------------------------------
STEAM_API_KEY="replace-with-steam-web-api-key"

# -----------------------------------------------------------------------------
# Supabase persistence
# Required for durable production storage of protected donation/support ledgers, webhook reconciliation, contact/report data, and multiplayer/admin server writes.
# NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are safe public client values.
# SUPABASE_SERVICE_ROLE_KEY is server-only and must stay secret.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"

# -----------------------------------------------------------------------------
# PayPal one-time protected donations
# Required for the Steam-linked protected one-time PayPal checkout flow:
# - NEXT_PUBLIC_PAYPAL_CLIENT_ID
# - PAYPAL_CLIENT_SECRET
# - PAYPAL_ENV (sandbox or live)
# - PAYPAL_CURRENCY (defaults to USD when omitted)
# PAYPAL_WEBHOOK_ID is required when receiving/verifying PayPal webhooks for durable reconciliation.
# Protected donations also depend on the app URL/session, Steam login, and Supabase settings above.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PAYPAL_CLIENT_ID="replace-with-paypal-client-id"
PAYPAL_CLIENT_SECRET="replace-with-paypal-client-secret"
PAYPAL_WEBHOOK_ID="replace-with-paypal-webhook-id"
PAYPAL_ENV="sandbox"
PAYPAL_CURRENCY="USD"

# -----------------------------------------------------------------------------
# PayPal recurring subscriptions
# Required in addition to the one-time PayPal settings when enabling Steam-linked recurring subscription purchases.
# Use the plan ID from the matching PayPal sandbox/live environment.
# -----------------------------------------------------------------------------
PAYPAL_SUBSCRIPTION_PLAN_ID="replace-with-paypal-subscription-plan-id"

# -----------------------------------------------------------------------------
# PayPal.Me fallback
# No environment variable is required for the current PayPal.Me fallback link; it is a direct external one-time gift path.
# It can be used without PayPal API credentials, but it may not automatically bind the gift to a Steam-linked protected donation record.
# -----------------------------------------------------------------------------
